# --- Vercel / ლოკალური (.env.local) ---

# Anthropic — სტრატეგიის AI (სერვერიდან, ბრაუზერში გასაღები აღარ არის საჭირო)
ANTHROPIC_API_KEY=

# Supabase (საჯარო — ფრონტისთვის, თუ მოგვიანებით დაუმატებთ supabase-js პირდაპირ HTML-ში)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# სერვერული წვდომა — მხოლოდ API routes / არასოდეს ბრაუზერში
SUPABASE_SERVICE_ROLE_KEY=

# სინქრონის საიდუმლო — იგივე უნდა გაიგზავნოს header-ში: x-warehouse-secret
WAREHOUSE_SYNC_SECRET=შეცვალეთ_გრძელი_შემთხვევითი_სტრიქონი
